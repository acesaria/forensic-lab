# config.yaml
# Machine-specific environment settings. Edit these per host.

host:
  ssh_key: ~/.ssh/forensics-lab
  ssh_pub_key: ~/.ssh/forensics-lab.pub
  libvirt_uri: qemu:///system
  isolated_network_name: forensics-isolated
  pool_name: forensic-lab-pool
  pool_path: /var/lib/forensic-lab/disks
  images_path: /var/lib/forensic-lab/images

role_defaults:
  lab:
    disk_size: 10G
    ram_mb: 2048
    vcpus: 2
    network: forensics-isolated
  build-isf:
    disk_size: 15G
    ram_mb: 6144
    vcpus: 4
    network: default