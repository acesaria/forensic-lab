#cloud-config
#
# Build VM for Volatility3 ISF generation via dwarf2json.
# Lifecycle: ephemeral — create, build, collect ISF, destroy.
# Internet access required (uses the 'default' libvirt network).

users:
  - name: labuser
    groups: [sudo]
    shell: /bin/bash
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDlWdCCwnaTPvbOirMa5/6jPGIzhLXMg89qc4GSuapNI forensics-lab

ssh_pwauth: false
disable_root: true
package_update: true
package_upgrade: false

packages:
  - build-essential
  - git
  - golang-go

runcmd:
  - systemctl mask systemd-networkd-wait-online.service
  - git clone https://github.com/volatilityfoundation/dwarf2json /opt/dwarf2json
  - cd /opt/dwarf2json && go build -o /usr/local/bin/dwarf2json .
