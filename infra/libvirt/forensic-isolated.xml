<network>
  <name>forensics-isolated</name>
  <bridge name="virbr-forensics" stp="on" delay="0"/>
  <ip address="192.168.100.1" netmask="255.255.255.0">
    <dhcp>
      <range start="192.168.100.10" end="192.168.100.50"/>
    </dhcp>
  </ip>
  <iptables>
    <rule action="accept" chain="FORWARD" direction="in" dev="virbr-forensics"/>
    <rule action="accept" chain="FORWARD" direction="out" dev="virbr-forensics"/>
</iptables>
  <!--
    No <forward> element: isolated mode.
    Guests can reach each other and the host (192.168.100.1),
    but no traffic is forwarded outside the host.
  -->
</network>
